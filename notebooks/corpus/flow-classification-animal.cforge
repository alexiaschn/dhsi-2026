          "code": "import json\nimport re\n\ndef evaluate(response):\n  answer = response.text\n  try:\n\n    res = json.loads(answer)\n\n    return response.meta['animal'] == str(res[0]['reponse']).lower()\n  except json.JSONDecodeError:\n      return 'decode error'\n  except (KeyError, IndexError, TypeError):\n      return 'keyerror'",
          "refresh": false,
